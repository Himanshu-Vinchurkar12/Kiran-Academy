package com.OPS;

public class OrderProcessing implements Runnable {
	
    private String orderId;

    public OrderProcessing(String orderId) {
    	this.orderId = orderId;
    }

	@Override
    public void run() {
        try {
        	System.out.println("Processing order: " + orderId);

            System.out.println(orderId + " - Payment started");
            Thread.sleep(1000);
            System.out.println(orderId + " - Payment sucessfull");

            Thread.sleep(1000);
            
            packing(orderId);
            
            Thread.sleep(1000);
            
            System.out.println(orderId + " - Shipment started");
            
            Thread.sleep(1000);
            
            System.out.println(orderId + " - Order Shipped");
        } catch (InterruptedException e) {
            e.printStackTrace();
        }
    }

    
	public static synchronized void packing(String orderId)  {
	    
	        System.out.println(orderId + " - Packing started");
	        try {
				Thread.sleep(1500);
			} catch (InterruptedException e) {
				// TODO Auto-generated catch block
				e.printStackTrace();
			}
	        System.out.println(orderId + " - Packing completed");

	}

}
